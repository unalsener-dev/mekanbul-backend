const database = 'mekanbul';
use(database);

// 1. Barida Cam Kafe Yorumları
db.venues.updateOne(
  { "name": "Barida Cam Kafe" },
  {
    $push: {
      "comments": {
        $each: [
          { "_id": ObjectId(), "author": "Sinan", "rating": 5, "text": "Manzarası harika, çaylar taze.", "date": new Date() },
          { "_id": ObjectId(), "author": "Ayşe", "rating": 4, "text": "Pastalar lezzetli ama biraz pahalı.", "date": new Date() },
          { "_id": ObjectId(), "author": "Mehmet", "rating": 3, "text": "Hafta sonu çok kalabalık oluyor, yer bulamadık.", "date": new Date() },
          { "_id": ObjectId(), "author": "Fatma", "rating": 5, "text": "Ders çalışmak için ideal bir sessizlikteydi.", "date": new Date() },
          { "_id": ObjectId(), "author": "Ali", "rating": 4, "text": "Personel güler yüzlü, servis hızlı.", "date": new Date() }
        ]
      }
    }
  }
);

// 2. Routine Burger Yorumları
