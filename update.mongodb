          { "_id": ObjectId(), "author": "Mustafa", "rating": 4, "text": "Pilav üstü döneri tavsiye ederim.", "date": new Date() },
          { "_id": ObjectId(), "author": "Gizem", "rating": 3, "text": "Ortalama bir lezzet, çok beklentiniz olmasın.", "date": new Date() }
        ]
      }
    }
  }
);

