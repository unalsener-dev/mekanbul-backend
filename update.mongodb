          { "_id": ObjectId(), "author": "Can", "rating": 5, "text": "Fatih mahallesindeki en iyi burgerci.", "date": new Date() },
          { "_id": ObjectId(), "author": "Zeynep", "rating": 3, "text": "Patatesler biraz soğuk geldi.", "date": new Date() },
          { "_id": ObjectId(), "author": "Burak", "rating": 5, "text": "Müzikler ve ortam çok cool.", "date": new Date() }
        ]
      }
    }
  }
);

// 3. Yesene Döner Yorumları
